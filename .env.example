NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_TOKEN_EXPIRATION_DAYS=1
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Sentry — error monitoring. Get the DSN from your Sentry project
# (Settings → Client Keys). Leave blank to disable Sentry (it no-ops).
NEXT_PUBLIC_SENTRY_DSN=
# Build-time only (set these in Vercel), needed for source-map upload:
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=